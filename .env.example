# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
# Comma-separated Slack user IDs allowed to use the bot (leave empty to allow all)
ALLOWED_SLACK_USERS=U01ABCDEF,U02GHIJKL

# GitHub
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=YourOrg
GITHUB_REPO=portpro-orderful-service

# Connection API (per org + env, each org/env has its own independent API)
# Medlog Prod
CONN_API_URL_MEDLOG_PROD=https://medlog-prod-api.example.com
CONN_API_TOKEN_MEDLOG_PROD=your-token
# Medlog Sandbox
CONN_API_URL_MEDLOG_SANDBOX=https://medlog-sandbox-api.example.com
CONN_API_TOKEN_MEDLOG_SANDBOX=your-token
# Universal Prod
CONN_API_URL_UNIVERSAL_PROD=https://universal-prod-api.example.com
CONN_API_TOKEN_UNIVERSAL_PROD=your-token
# Universal Sandbox
CONN_API_URL_UNIVERSAL_SANDBOX=https://universal-sandbox-api.example.com
CONN_API_TOKEN_UNIVERSAL_SANDBOX=your-token
# Forward Air Prod
CONN_API_URL_FORWARDAIR_PROD=https://forwardair-prod-api.example.com
CONN_API_TOKEN_FORWARDAIR_PROD=your-token
# Port Pro Prod
CONN_API_URL_PORTPRO_PROD=https://portpro-prod-api.example.com
CONN_API_TOKEN_PORTPRO_PROD=your-token

# Local git clone (auto-cloned on first Docker run; for local dev clone manually)
REPO_LOCAL_PATH=./repo-workspace
